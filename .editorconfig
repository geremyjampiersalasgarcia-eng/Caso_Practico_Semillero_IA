# ==================================================
# EditorConfig - Consistent coding styles across IDEs
# https://editorconfig.org
# ==================================================

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

[*.py]
indent_size = 4

[*.{ts,tsx,js,jsx,json,css}]
indent_size = 2

[*.{yml,yaml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
