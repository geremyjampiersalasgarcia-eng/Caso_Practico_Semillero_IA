# ==================================================
# Environment Variables Template
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ==================================================

# --- Google Gemini API ---
# Get your key from: https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# --- LLM Configuration ---
# Model for agents (gemini-2.5-flash recommended)
LLM_MODEL_NAME=gemini-2.5-flash
# Model for embeddings
EMBEDDING_MODEL_NAME=models/gemini-embedding-001
# Temperature for LLM responses (0.0 = deterministic, 1.0 = creative)
LLM_TEMPERATURE=0.1

# --- ChromaDB ---
# Path where ChromaDB stores its data (relative to backend/)
CHROMA_PERSIST_DIR=data/chroma_db

# --- RAG Configuration ---
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVAL_TOP_K=4

# --- API Configuration ---
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=true

# --- CORS ---
CORS_ORIGINS=["http://localhost:3000"]

# --- Logging ---
LOG_LEVEL=INFO

# --- Database (PostgreSQL via Docker) ---
# Si PostgreSQL no está disponible, el sistema usa SQLite como fallback automático
DATABASE_URL=postgresql://mesa_ayuda_user:mesa_ayuda_pass_2024@127.0.0.1:5433/mesa_ayuda_db
