# ==================================================
# Environment Variables Template
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ==================================================

# --- Google Gemini API ---
# Get your key from: https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# --- LLM Configuration ---
# Model for agents (gemini-1.5-flash is faster/cheaper, gemini-1.5-pro is more capable)
LLM_MODEL_NAME=gemini-1.5-flash
# Model for embeddings
EMBEDDING_MODEL_NAME=models/text-embedding-004
# Temperature for LLM responses (0.0 = deterministic, 1.0 = creative)
LLM_TEMPERATURE=0.1

# --- ChromaDB ---
# Path where ChromaDB stores its data (relative to backend/)
CHROMA_PERSIST_DIR=data/chroma_db

# --- RAG Configuration ---
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVAL_TOP_K=4

# --- API Configuration ---
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=true

# --- CORS ---
CORS_ORIGINS=["http://localhost:3000"]

# --- Logging ---
LOG_LEVEL=INFO
